APP_NAME="Auto Workshop Manager"
APP_CURRENCY="Rs."
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="info@totaldrivecare.com"
MAIL_FROM_NAME="${APP_NAME}"

# FitSMS Settings
FITSMS_API_TOKEN="your_fitsms_api_token"
FITSMS_SENDER_ID="TDC"
NOTIFICATION_MOCK=true

# Backups Settings
BACKUP_DIR=/var/www/html/backups

# Default Super Manager Account Credentials (for auto seeding)
ADMIN_EMAIL="admin@totaldrivecare.com"
ADMIN_PASSWORD="Password123!"

VITE_APP_NAME="${APP_NAME}"
